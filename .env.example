# Copy to .env for local Docker Compose overrides.
# Do not commit real production secrets.

APP_ENV=development

POSTGRES_DB=legal_doc_ai
POSTGRES_USER=legal
POSTGRES_PASSWORD=legal

DATABASE_URL=postgresql+psycopg://legal:legal@postgres:5432/legal_doc_ai
REDIS_URL=redis://redis:6379/0
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=document_chunks
UPLOAD_DIR=/data/uploads
UPLOAD_MAX_FILE_SIZE_BYTES=52428800
UPLOAD_MAX_FILES_PER_REQUEST=20
UPLOAD_MAX_ZIP_SIZE_BYTES=209715200

JWT_SECRET_KEY=local-dev-secret
# In development, private LAN origins are also allowed via API CORS regex.
# Add explicit origins here if you use a custom hostname.
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin123
ADMIN_FULL_NAME=System Admin

NUXT_PUBLIC_API_BASE=http://localhost:8000/api/v1
NUXT_PUBLIC_UPLOAD_MAX_FILE_SIZE_MB=50
NUXT_PUBLIC_UPLOAD_MAX_FILES=20
NUXT_PUBLIC_UPLOAD_MAX_ZIP_SIZE_MB=200

EMBEDDING_BACKEND=fake
EMBEDDING_MODEL_NAME=bkai-foundation-models/vietnamese-bi-encoder
EMBEDDING_MODEL_PATH=/models/embeddings/bkai-vietnamese-bi-encoder
EMBEDDING_DEVICE=cpu
EMBEDDING_DIMENSIONS=384
EMBEDDING_BATCH_SIZE=16
EMBEDDING_LOCAL_FILES_ONLY=true
ALLOW_FAKE_EMBEDDINGS=true

CHUNKING_BACKEND=ocr_chunking
OCR_ENGINE=paddle_vietocr
OCR_LANG=vi
OCR_USE_GPU=false
OCR_DEVICE=cpu
OCR_MODEL_DIR=/models/ocr
OCR_PREPROCESS_MODE=auto
OCR_MIN_CONFIDENCE=0.0
OCR_RESTORE_VIETNAMESE_TERMS=true
OCR_FALLBACK_ENGINE=
VIETOCR_MODEL_DIR=/models/ocr/vietocr
VIETOCR_DEVICE=cpu
VIETOCR_CONFIG=vgg_transformer
VIETOCR_WEIGHT_PATH=/models/ocr/vietocr/transformerocr.pth
VIETOCR_MAX_BATCH_SIZE=1
VIETOCR_BEAMSEARCH=false

# RAG generative local LLM (optional — requires `docker compose --profile llm`)
RAG_GENERATION_BACKEND=extractive
OLLAMA_BASE_URL=http://ollama:11434
RAG_LLM_MODEL=qwen2.5:3b-instruct
RAG_LLM_TIMEOUT_SECONDS=120
RAG_LLM_MAX_CONTEXT_CHARS=8000
RAG_LLM_MAX_OUTPUT_TOKENS=512
RAG_LLM_TEMPERATURE=0.1
OLLAMA_NUM_PARALLEL=1
OLLAMA_MAX_LOADED_MODELS=1

# Docker Compose resource limits (optional overrides)
POSTGRES_CPU_LIMIT=1
POSTGRES_MEMORY_LIMIT=1G
REDIS_CPU_LIMIT=0.5
REDIS_MEMORY_LIMIT=512M
QDRANT_CPU_LIMIT=1
QDRANT_MEMORY_LIMIT=2G
API_CPU_LIMIT=1
API_MEMORY_LIMIT=2G
WORKER_CPU_LIMIT=2
WORKER_MEMORY_LIMIT=4G
WEB_CPU_LIMIT=0.5
WEB_MEMORY_LIMIT=512M
OLLAMA_CPU_LIMIT=2
OLLAMA_MEMORY_LIMIT=6G

# Enable generative RAG after starting profile llm and pulling a model:
# See docs/RAG_LLM_RUNBOOK.md
# RAG_GENERATION_BACKEND=ollama
# docker compose --profile llm up -d
# docker compose exec ollama ollama pull qwen2.5:3b-instruct

# Production minimums:
# - APP_ENV=production
# - JWT_SECRET_KEY must be a strong value with at least 32 characters.
# - ADMIN_PASSWORD must not be admin123 and must have at least 12 characters.
# - CORS_ALLOWED_ORIGINS must list explicit internal web origins; do not use *.
# - POSTGRES_PASSWORD and DATABASE_URL must use a non-default password.
